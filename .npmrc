# ConnectKit (1.9.x) still pins its peer dep to wagmi 2.x, but Branium uses
# wagmi 3.x. The hook + connector surface we touch (useConnect, useAccount,
# useModal, createConfig, http) is the same across both majors, so the
# resolution conflict is paper-only — runtime is fine. Without this flag
# `npm install` on Vercel fails with ERESOLVE and the build aborts before
# Next.js even starts.
#
# Revisit when ConnectKit ships a release that lists wagmi >=3 (track:
# https://github.com/family/connectkit/issues — search "wagmi 3").
legacy-peer-deps=true
