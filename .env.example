# =============================================================================
# Branium — environment variables (copy to .env.local; never commit secrets)
# =============================================================================

# ── Mantle contract ───────────────────────────────────────────────────────────
# Mantle Sepolia contract deployment.
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
# NEXT_PUBLIC_DEPLOY_BLOCK=0
# NEXT_PUBLIC_MANTLE_RPC=https://rpc.sepolia.mantle.xyz
# MANTLE_RPC=https://rpc.sepolia.mantle.xyz

# Deploy locally with:
#   npm run compile:contract
#   DEPLOYER_PRIVATE_KEY=0x... ORACLE_ADDRESS=0x... npm run deploy:contract

# ── Wallet connect ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_WC_PROJECT_ID=

# ── Agent Mantle signers ──────────────────────────────────────────────────────
# These keys send real Mantle Sepolia transactions. Keep them server-only.
# ORACLE_PRIVATE_KEY=0x...
# MARKET_CREATOR_PRIVATE_KEY=0x...
# PANEL_MOMENTUM_PRIVATE_KEY=0x...
# PANEL_RISK_PRIVATE_KEY=0x...
# PANEL_CONTRARIAN_PRIVATE_KEY=0x...
# PANEL_SIGNAL_PRIVATE_KEY=0x...
# PANEL_LIQUIDITY_PRIVATE_KEY=0x...
# PANEL_TOKEN_PRIVATE_KEY=0x...
# PANEL_MATCH_PRIVATE_KEY=0x...
# PANEL_WEATHER_PRIVATE_KEY=0x...
# PANEL_STRESS_PRIVATE_KEY=0x...
# PANEL_PULSE_PRIVATE_KEY=0x...

# ── Agent model keys ──────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Worker-specific keys override shared keys for that worker.
# ORACLE_OPENROUTER_API_KEY=
# CREATOR_OPENROUTER_API_KEY=
# PANELS_OPENROUTER_API_KEY=

# ── Oracle agent ──────────────────────────────────────────────────────────────
# npm run oracle
# AGENT_RUN_ONCE=1
# AUTO_CHALLENGE=1
# CHALLENGE_STAKE_MNT=2
# CHALLENGE_CONFIDENCE=80
# ORACLE_LLM_THROTTLE_MS=0
# ORACLE_POLL_INTERVAL_MS=60000

# ── Market creator agent ──────────────────────────────────────────────────────
# npm run market-creator
# AGENT_RUN_ONCE=1
# CREATOR_STAKE_MNT=2
# MAX_CLAIMS_PER_RUN=5
# MAX_ACTIVE_CLAIMS=10
# RUN_INTERVAL_HOURS=6

# ── Data/cache features ───────────────────────────────────────────────────────
# DATABASE_URL=postgresql://<user>:<pwd>@<host>/<db>?sslmode=require
# CRON_SECRET=

# ── Claim drafting and moderation ─────────────────────────────────────────────
# NEXT_PUBLIC_FEATURE_SOURCE_DRAFTS=1
# NEXT_PUBLIC_FEATURE_CLAIM_MODERATION=1
